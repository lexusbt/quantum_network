# Environment Variables for Quantum Network Routing Project
# Copy this file to .env and fill in your values

# Project Paths
PROJECT_ROOT=/path/to/quantum-network-routing-qaoa
DATA_DIR=/path/to/data

# IBM Quantum (if using real quantum hardware)
IBMQ_TOKEN=your_ibm_quantum_token_here
IBMQ_HUB=ibm-q
IBMQ_GROUP=open
IBMQ_PROJECT=main

# Experiment Tracking (optional)
MLFLOW_TRACKING_URI=file:./mlruns
WANDB_API_KEY=your_wandb_key_here
WANDB_PROJECT=quantum-routing

# Compute Resources
MAX_WORKERS=4
USE_GPU=false

# Random Seeds
RANDOM_SEED=42
NUMPY_SEED=42
